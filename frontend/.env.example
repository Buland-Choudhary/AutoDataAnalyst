# Optional override for backend API URL
# Leave unset to auto-switch:
# - local dev (npm run dev) => http://127.0.0.1:8000
# - production build/deploy => https://autodataanalyst.onrender.com
VITE_API_BASE_URL=

# Telemetry (deploy only by default; local access is automatically skipped)
VITE_TELEMETRY_ENABLED=true
VITE_NOTIFY_BACKEND_URL=https://portfolio-rkfu.onrender.com/notify
VITE_NOTIFY_MAX_ATTEMPTS=3
VITE_NOTIFY_RETRY_DELAY_MS=3000
